# ────────────────────────────────────────────────────────────────────────────
# Our Story — Backend Configuration
# Copy this file to .env.local and fill in your credentials.
# NEVER commit .env.local to git.
# ────────────────────────────────────────────────────────────────────────────

# ── Firebase (Auth + Chat + Storage) ────────────────────────────────────────
# Go to https://console.firebase.google.com → Your project → Project settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── MongoDB Atlas (Content database) ────────────────────────────────────────
# Go to https://cloud.mongodb.com → App Services → Your app → Authentication → API Keys
# Also enable the Data API in: App Services → Hosting → Data API
VITE_MONGODB_APP_ID=your-atlas-app-id
VITE_MONGODB_API_KEY=your-atlas-api-key
VITE_MONGODB_DATA_SOURCE=Cluster0
VITE_MONGODB_DATABASE=our-story

# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ─────────────────────────────────────────────────────────────────────────────
#
# FIREBASE SETUP:
# 1. Go to firebase.google.com → Create project "our-story"
# 2. Add a Web app → copy the config above
# 3. Enable Authentication → Email/Password provider
# 4. Enable Firestore Database → Start in production mode → choose africa-south1
# 5. Enable Storage → Start in production mode
# 6. In Firestore rules, paste:
#    rules_version = '2';
#    service cloud.firestore {
#      match /databases/{database}/documents {
#        match /messages/{msg} {
#          allow read, write: if request.auth != null;
#        }
#        match /users/{userId} {
#          allow read, write: if request.auth != null;
#        }
#        match /content/{doc} {
#          allow read, write: if request.auth != null;
#        }
#      }
#    }
#
# MONGODB ATLAS SETUP:
# 1. Go to cloud.mongodb.com → Create free cluster (M0) → name "Cluster0"
# 2. Choose AWS / ap-southeast-2 (closest to SA)
# 3. Create database "our-story" with collections:
#    letters, dreams, memories, gallery, profiles
# 4. Go to App Services → Create application → "our-story-app"
# 5. Enable Authentication → API Key provider → Create API key
# 6. Enable Data API → copy App ID
# 7. Set Data API rules to allow authenticated access
#
# LOGIN CREDENTIALS (already configured in the app):
# - Phathu:  phathu@ourstory.app  / password = your dating start date (08052026)
# - Ayanda:  ayanda@ourstory.app  / password = your dating start date (08052026)
# Run: npm run setup-firebase   ← creates these accounts automatically
