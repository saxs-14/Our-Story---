# ─────────────────────────────────────────────────────────────────────────────
# Our Story -- Firebase Configuration
# Copy this file to .env.local and fill in your credentials.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Go to https://console.firebase.google.com → Your project → Project settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS (one-time, takes ~10 minutes)
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Go to firebase.google.com → Create project "our-story" → Continue
#    (Disable Google Analytics, not needed)
#
# 2. Add a Web app → nickname "our-story-web" → Register app
#    Copy the config values into this file above.
#
# 3. Authentication
#    Left sidebar → Authentication → Sign-in method → Email/Password → Enable → Save
#
# 4. Firestore Database
#    Left sidebar → Firestore Database → Create database
#    Choose: Production mode → Next
#    Location: africa-south1 (Johannesburg) → Enable
#    Then go to Rules tab and replace everything with:
#
#      rules_version = '2';
#      service cloud.firestore {
#        match /databases/{database}/documents {
#          match /{document=**} {
#            allow read, write: if request.auth != null;
#          }
#        }
#      }
#
#    Click Publish.
#
# 5. Storage
#    Left sidebar → Storage → Get started → Production mode → Next
#    Same region (africa-south1) → Done
#    Go to Rules tab and replace with:
#
#      rules_version = '2';
#      service firebase.storage {
#        match /b/{bucket}/o {
#          match /{allPaths=**} {
#            allow read, write: if request.auth != null;
#          }
#        }
#      }
#
#    Click Publish.
#
# That is it! Run: npm run dev
#
# The app will automatically create accounts for both partners on first login:
#   Phathu:  phathu@ourstory.app  / password = 08052026
#   Ayanda:  ayanda@ourstory.app  / password = 08052026
#
# Everything (chat, letters, dreams, memories, photos) syncs through Firebase.
